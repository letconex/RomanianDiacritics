                </prop>
                <prop oor:name="Title" oor:type="xs:string">
                    <value xml:lang="en">Replace Cedilla below with Comma bellow</value>
                    <value xml:lang="de">Cedille darunter durch Komma darunter ersetzen</value>
                    <value xml:lang="ro">Înlocuiește sedilele dedesubt cu virgule dedesubt</value>
                </prop>
                <prop oor:name="Target" oor:type="xs:string">
                    <value>_self</value>
                </prop>
            </node>

