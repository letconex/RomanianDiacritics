        <node oor:name="AddonMenu">

            <node oor:name="LibraryDiacritice.AddonMenu.m01" oor:op="replace">
                <prop oor:name="Context" oor:type="xs:string">
                    <value>com.sun.star.text.TextDocument,,,com.sun.star.script.BasicIDE</value>
                </prop>
                <prop oor:name="Title" oor:type="xs:string">
                    <value xml:lang="en">Characters with diacritical marks replacement</value>
                    <value xml:lang="de">Zeichen mit diakritischen Zeichen ersetzen</value>
                    <value xml:lang="ro">Înlocuire de caractere cu diacritice</value>
                </prop>

                <node oor:name="Submenu">
                </node>

            </node>

            <node oor:name="LibraryDiacritice.AddonMenu.m02" oor:op="replace">
                <prop oor:name="Context" oor:type="xs:string">
                    <value>com.sun.star.text.TextDocument,,,com.sun.star.script.BasicIDE</value>
                </prop>
                <prop oor:name="URL" oor:type="xs:string">
                  <value>vnd.sun.star.script:LibraryDiacritice.module_diacritics_xchange.ReplaceDiacritics2ASCII?language=Basic&amp;location=application</value>
                </prop>

                <prop oor:name="Title" oor:type="xs:string">
                    <value xml:lang="en">Replace all Romanian diacritics with ASCII</value>
                    <value xml:lang="de">Alle rumänischen diakritischen Zeichen durch ASCII Zeichen ersetzen</value>
                    <value xml:lang="ro">Înlocuiește toate diacriticele românești cu caractere ASCII</value>
                </prop>
                <prop oor:name="Target" oor:type="xs:string">
                    <value>_self</value>
                </prop>
            </node>

            <node oor:name="LibraryDiacritice.AddonMenu.m03" oor:op="replace">
                <prop oor:name="Context" oor:type="xs:string">
                    <value>com.sun.star.text.TextDocument,,,com.sun.star.script.BasicIDE</value>
                </prop>
                <prop oor:name="URL" oor:type="xs:string">
                    <value>vnd.sun.star.script:LibraryDiacritice.module_diacritics_xchange.ReplaceComma2Cedilla?language=Basic&amp;location=application</value>
                </prop>
                <prop oor:name="Title" oor:type="xs:string">
                    <value xml:lang="en">Replace Comma bellow with Cedilla below</value>
                    <value xml:lang="de">Komma darunter durch Cedille darunter ersetzen</value>
                    <value xml:lang="ro">Înlocuiește virgulele dedesubt cu sedile dedesubt</value>
                </prop>
                <prop oor:name="Target" oor:type="xs:string">
                    <value>_self</value>
                </prop>
            </node>

            <node oor:name="LibraryDiacritice.AddonMenu.m04" oor:op="replace">
                <prop oor:name="Context" oor:type="xs:string">
                    <value>com.sun.star.text.TextDocument,,,com.sun.star.script.BasicIDE</value>
