        Else
            MsgBox ("All Romanian characters with comma below were replaced with characters with cedilla bellow." + chr(13) + Join(dynArray,  vbLf) + chr(13) + "Total characters replaced: " + TotalFound, 64)
        End If

    End If

End Sub

</script:module>
