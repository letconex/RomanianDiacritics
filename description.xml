<?xml version="1.0" encoding="UTF-8"?>
<description
    xmlns="http://openoffice.org/extensions/description/2006"
    xmlns:dep="http://openoffice.org/extensions/description/2006"
    xmlns:lo="http://libreoffice.org/extensions/description/2011"
    xmlns:xlink="http://www.w3.org/1999/xlink">
    <identifier value="vnd.leontiberiucristian.librarydiacritics" />
    <version value="1.1.3"/>
    <dependencies>
        <OpenOffice.org-minimal-version value="2.1" dep:name="OpenOffice.org 2.1"/>
    </dependencies>
    
    <registration>
		<simple-license accept-by="user" suppress-on-update="true">
			<license-text xlink:href="registration/license_en.txt" lang="en" />
			<license-text xlink:href="registration/license_de.txt" lang="de" />
			<license-text xlink:href="registration/license_ro.txt" lang="ro" />
		</simple-license>
    </registration>

    <update-information>
        <src xlink:href="https://github.com/letconex/RomanianDiacritics/blob/main/extension.update.xml" />
    </update-information>
  
    <publisher>
        <name xlink:href="https://letconex.blogspot.com" lang="en">Tiberiu-Cristian Leon</name>
        <name xlink:href="https://letconex.blogspot.com" lang="de">Tiberiu-Cristian Leon</name>
        <name xlink:href="https://letconex.blogspot.com" lang="ro">Tiberiu-Cristian Leon</name>
    </publisher>

    <extension-description>
        <src xlink:href="extension-description/pkg-description_en.txt" lang="en" />
        <src xlink:href="extension-description/pkg-description_de.txt" lang="de" />
        <src xlink:href="extension-description/pkg-description_ro.txt" lang="ro" />
    </extension-description>

    <release-notes>
        <src xlink:href="extension-description/release-notes_en.txt" lang="en" />
        <src xlink:href="extension-description/release-notes_de.txt" lang="de" />
        <src xlink:href="extension-description/release-notes_ro.txt" lang="ro" />
    </release-notes>

    <display-name>
        <name lang="en">Romanian Diacritics</name>
        <name lang="de">Rumänische Diakritika</name>
        <name lang="ro">Diacritice românești</name>
    </display-name>

    <icon>
    <default xlink:href="icons/diacritice.png" />
    <high-contrast xlink:href="icons/diacriticehighcontrast.png" />
  </icon>

    <platform value="all" />
</description>
